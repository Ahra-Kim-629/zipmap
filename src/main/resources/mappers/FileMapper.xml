    <!--    &lt;!&ndash; 여기부터 코드 추가 수정필요    &ndash;&gt;-->

    <insert id="insertFile" parameterType="com.daedong.zipmap.domain.File"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file
        (target_type, target_id, file_path, file_size)
        VALUES
        (#{targetType}, #{targetId}, #{filePath}, #{fileSize})
    </insert>

    <select id="findAllByTargetTypeAndTargetId" resultType="com.daedong.zipmap.domain.File">
        SELECT
        id, target_type, target_id, file_path, file_size, created_at, updated_at
        FROM file
        WHERE target_type = #{targetType}
        AND target_id = #{targetId}
    </select>

    <select id="findAttachments" resultType="com.daedong.zipmap.domain.File">
        SELECT * FROM file_attachment
        WHERE target_type = #{targetType}
        AND target_id = #{targetId}
    </select>

    <select id="findAttachmentById" resultType="com.daedong.zipmap.domain.File">
        SELECT * FROM file_attachment WHERE id = #{id}
    </select>

    <delete id="deleteFileById">
        DELETE FROM file WHERE id = #{id}
    </delete>

    <delete id="deleteFilesAllByTargetTypeAndTargetId">
        DELETE FROM file
        WHERE target_type = #{targetType}
        AND target_id = #{targetId}
    </delete>

