<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.daedong.zipmap.mapper.PostMapper">
    <resultMap id="postResultMap" type="com.daedong.zipmap.domain.PostDTO">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="userId" column="user_id"/>
        <result property="category" column="category"/>
        <result property="location" column="location"/>
        <result property="likeCount" column="like_count"/>
        <result property="dislikeCount" column="dislike_count"/>
        <result property="postStatus" column="post_status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>

        <collection property="reactionList" ofType="com.daedong.zipmap.domain.PostReaction">
            <result property="id" column="reaction_id"/>
            <result property="type" column="type"/>
            <result property="createdAt" column="reaction_created_at"/>
            <result property="updatedAt" column="reaction_updated_at"/>
        </collection>

        <collection property="fileList" ofType="com.daedong.zipmap.domain.PostFile">
            <result property="id" column="file_id"/>
            <result property="filePath" column="file_path"/>
            <result property="createdAt" column="file_created_at"/>
            <result property="updatedAt" column="file_updated_at"/>
        </collection>

        <collection property="replyList" ofType="com.daedong.zipmap.domain.PostReply">
            <result property="id" column="reply_id"/>
            <result property="content" column="reply_content"/>
            <result property="createdAt" column="reply_created_at"/>
            <result property="updatedAt" column="reply_updated_at"/>
        </collection>
    </resultMap>

    <select id="findById" resultMap="postResultMap">
        SELECT
        p.id, p.title, p.content, p.user_id, p.category, p.location,
        p.like_count, p.dislike_count, p.post_status, p.created_at, p.updated_at,
        r.id as reaction_id, r.type, r.created_at as reaction_created_at, r.updated_at as reaction_updated_at,
        f.id as file_id, f.file_path, f.created_at as file_created_at, f.updated_at as file_updated_at,
        c.id as reply_id, c.content as reply_content, c.created_at as reply_created_at, c.updated_at as reply_updated_at
        FROM
        post p
        LEFT JOIN post_reaction r ON p.id = r.post_id
        LEFT JOIN post_file f on p.id = f.post_id
        LEFT JOIN post_reply c on p.id = c.post_id
        WHERE
        p.id = #{id}
    </select>

    <select id="findAll" resultType="com.daedong.zipmap.domain.Post">
        SELECT * FROM POST
        <where>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="location != null and location != ''">
                AND location = #{location}
            </if>
            <if test="keyword != null and keyword != ''">
                <choose>
                    <when test="searchType == 'title'">
                        AND title LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <when test="searchType == 'content'">
                        AND content LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <otherwise>
                        AND title LIKE CONCAT('%', #{keyword}, '%')
                    </otherwise>
                </choose>
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{pageable.pageSize} OFFSET #{pageable.offset}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM POST
        <where>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="location != null and location != ''">
                AND location = #{location}
            </if>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <select id="count" resultType="int">
        SELECT count(*)
        FROM Post
        <where>
            <if test="searchType == 'title' and key != null and key != ''">
                AND title LIKE CONCAT('%', #{key}, '%')
            </if>
            <if test="searchType == 'content' and key != null and key != ''">
                AND content LIKE CONCAT('%', #{key}, '%')
            </if>
        </where>
    </select>

    <insert id="insertPost" parameterType="com.daedong.zipmap.domain.Post"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post (
            title, content, user_id, category, location, 
            like_count, dislike_count, post_status, created_at, updated_at
        )
        VALUES (
            #{title}, #{content}, #{userId}, #{category}, #{location}, 
            0, 0, 'ACTIVE', NOW(), NOW()
        )
    </insert>

    <insert id="insertFile" parameterType="com.daedong.zipmap.domain.PostFile">
        INSERT INTO post_file (post_id, file_path)
        VALUES (#{postId}, #{filePath})
    </insert>
    <!-- 게시글 댓글 기능 관련 추가 쿼리 -->
    <insert id="insertReply" parameterType="com.daedong.zipmap.domain.PostReply">
        INSERT INTO post_reply (post_id, user_id, content, created_at)
        VALUES (#{postId}, #{userId}, #{content}, NOW())
    </insert>
</mapper>
