<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.daedong.zipmap.mapper.ReviewMapper">

    <!-- 리뷰의 댓글 아이디로 찾기 -->
    <select id="findReplyById" resultType="com.daedong.zipmap.domain.ReviewReply">
        SELECT id, review_id, user_id, content, created_at, updated_at
        FROM review_reply
        WHERE id = #{id}
    </select>

    <!-- 리뷰의 댓글 추가 -->
    <insert id="addReply" parameterType="com.daedong.zipmap.domain.ReviewReply">
        INSERT INTO review_reply
        (review_id, user_id, content)
        VALUES
        (#{reviewId}, #{userId}, #{content})
    </insert>

    <!-- 리뷰의 댓글 수정 -->
    <update id="updateReply" parameterType="com.daedong.zipmap.domain.ReviewReply">
        UPDATE review_reply
        SET content = #{content}
        WHERE id = #{id}
    </update>

    <!-- 리뷰의 댓글 삭제 -->
    <delete id="deleteReply" parameterType="long">
        DELETE FROM review_reply
        WHERE id = #{id}
    </delete>

</mapper>